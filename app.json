{
  "expo": {
    "name": "Ascending TimeForge",
    "slug": "Ascending",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon-ascending.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/icon-ascending.png",
      "resizeMode": "cover",
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.tasks"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon-ascending.png",
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.tasks"
    },
    "web": {
      "favicon": "./src/assets/ascending-logo.png"
    },
    "plugins": ["expo-secure-store"]
  }
}
